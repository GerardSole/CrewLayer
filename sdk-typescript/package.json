{
  "name": "crewlayer",
  "version": "0.1.0",
  "description": "Official TypeScript/JavaScript SDK for the CrewLayer AI agent backend",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./integrations/vercel-ai": {
      "import": {
        "types": "./dist/integrations/vercel-ai.d.ts",
        "default": "./dist/integrations/vercel-ai.js"
      },
      "require": {
        "types": "./dist/integrations/vercel-ai.d.cts",
        "default": "./dist/integrations/vercel-ai.cjs"
      }
    }
  },
  "peerDependencies": {
    "ai": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "crewlayer",
    "memory",
    "typescript"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
